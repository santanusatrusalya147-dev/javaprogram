#display n natural number
import java.util.*;
class Test
{
    public static void main(String arg[])
    {
       Scanner sc=new Scanner(System.in);
       System.out.println("enter n value ");
       int n=sc.nextInt();
       int j;
       for(j=1;j<=n;j++)
        System.out.print(j+"\t");
        System.out.println();
    }
}




